# Flask
SECRET_KEY=dev-secret-key-change-in-production
DEBUG=True

# Database (SQLite local por defecto, no se necesita configurar)
# DATABASE_URL=sqlite:///pesajes.db
# STATION_DATA_ROOT=C:\ProgramData\EnvaPeru\Pesaje
# BACKUP_RETENTION_COUNT=14

# Logs release: un solo archivo compartido bajo ProgramData, en UTC.
LOG_FILE_LEVEL=INFO
LOG_CONSOLE_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10
LOG_ROTATION_RETRY_SECONDS=300

# Scale (Balanza)
SCALE_PORT=COM4
SCALE_BAUD_RATE=9600

# Printer (TSC TE200)
PRINTER_TYPE=TSPL
PRINTER_NAME=TSC TE200

# API
API_PORT=5050

# Identidad y monitoreo con Backend Central
STATION_CODE=PESAJE-PLANTA-01
STATION_MODE=MONITORED_LEGACY
STATION_APP_VERSION=1.1.0-pilot
CENTRAL_ORIGIN=http://127.0.0.1:5000
ALLOW_INSECURE_CENTRAL=false
MONITORING_ENABLED=true
HEARTBEAT_SECONDS=30

# Compatibilidad legacy. No habilitar para el piloto monitoreado.
CENTRAL_API_URL=http://127.0.0.1:5000/api
SYNC_INTERVAL_SECONDS=300
SYNC_ENABLED=false

# El token central nunca se guarda en este archivo. Se provisiona con
# backend\station_control.py provision-token y queda cifrado con DPAPI.
