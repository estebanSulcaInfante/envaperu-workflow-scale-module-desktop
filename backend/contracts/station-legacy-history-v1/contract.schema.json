{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.envaperu.local/station/legacy-history/v1/contract.schema.json",
  "title": "EnvaPeru station legacy history v1",
  "$defs": {
    "nullableText": {
      "type": ["string", "null"],
      "maxLength": 300
    },
    "manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_sha256",
        "source_size_bytes",
        "source_schema_version",
        "source_total_rows",
        "source_active_rows",
        "source_deleted_rows",
        "source_first_capture_local",
        "source_last_capture_local"
      ],
      "properties": {
        "source_sha256": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "source_size_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "source_schema_version": {
          "type": "integer",
          "minimum": 0
        },
        "source_total_rows": {
          "type": "integer",
          "minimum": 0
        },
        "source_active_rows": {
          "type": "integer",
          "minimum": 0
        },
        "source_deleted_rows": {
          "type": "integer",
          "minimum": 0
        },
        "source_first_capture_local": {
          "$ref": "#/$defs/nullableText"
        },
        "source_last_capture_local": {
          "$ref": "#/$defs/nullableText"
        }
      }
    },
    "row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "legacy_id",
        "weight_kg",
        "captured_at_local",
        "deleted_at_local",
        "op",
        "ot",
        "mold",
        "color",
        "machine_code",
        "shift",
        "operator",
        "raw"
      ],
      "properties": {
        "legacy_id": {
          "type": "integer",
          "minimum": 1
        },
        "weight_kg": {
          "type": "string",
          "pattern": "^[0-9]+(\\.[0-9]{1,3})?$"
        },
        "captured_at_local": {
          "type": "string",
          "minLength": 10,
          "maxLength": 40
        },
        "deleted_at_local": {
          "$ref": "#/$defs/nullableText"
        },
        "op": {
          "$ref": "#/$defs/nullableText"
        },
        "ot": {
          "$ref": "#/$defs/nullableText"
        },
        "mold": {
          "$ref": "#/$defs/nullableText"
        },
        "color": {
          "$ref": "#/$defs/nullableText"
        },
        "machine_code": {
          "$ref": "#/$defs/nullableText"
        },
        "shift": {
          "$ref": "#/$defs/nullableText"
        },
        "operator": {
          "$ref": "#/$defs/nullableText"
        },
        "raw": {
          "type": "object"
        }
      }
    },
    "closure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "mold", "reason", "closed_at_local"],
      "properties": {
        "op": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50
        },
        "mold": {
          "$ref": "#/$defs/nullableText"
        },
        "reason": {
          "$ref": "#/$defs/nullableText"
        },
        "closed_at_local": {
          "type": "string",
          "minLength": 10,
          "maxLength": 40
        }
      }
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_version",
        "import_id",
        "manifest",
        "chunk_index",
        "total_chunks",
        "rows",
        "closures"
      ],
      "properties": {
        "contract_version": {
          "const": "station-legacy-history-v1"
        },
        "import_id": {
          "type": "string",
          "format": "uuid"
        },
        "manifest": {
          "$ref": "#/$defs/manifest"
        },
        "chunk_index": {
          "type": "integer",
          "minimum": 0
        },
        "total_chunks": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10000
        },
        "rows": {
          "type": "array",
          "maxItems": 500,
          "items": {
            "$ref": "#/$defs/row"
          }
        },
        "closures": {
          "type": "array",
          "maxItems": 500,
          "items": {
            "$ref": "#/$defs/closure"
          }
        }
      }
    },
    "response": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "accepted",
        "station_id",
        "import_id",
        "chunk_index",
        "chunks_received",
        "total_chunks",
        "status",
        "received_at_utc"
      ],
      "properties": {
        "accepted": {
          "const": true
        },
        "station_id": {
          "type": "string",
          "format": "uuid"
        },
        "import_id": {
          "type": "string",
          "format": "uuid"
        },
        "chunk_index": {
          "type": "integer",
          "minimum": 0
        },
        "chunks_received": {
          "type": "integer",
          "minimum": 1
        },
        "total_chunks": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "enum": ["RECEIVING", "COMPLETE"]
        },
        "received_at_utc": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}

