{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.envaperu.local/station/production-progress/v1/contract.schema.json",
  "title": "EnvaPeru station production progress v1",
  "$defs": {
    "progress_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operational_date",
        "op",
        "ot",
        "mold",
        "color",
        "machine_code",
        "shift",
        "bags",
        "weight_kg",
        "first_capture_at_utc",
        "last_capture_at_utc"
      ],
      "properties": {
        "operational_date": {"type": "string", "format": "date"},
        "op": {"type": ["string", "null"], "maxLength": 20},
        "ot": {"type": ["string", "null"], "maxLength": 20},
        "mold": {"type": ["string", "null"], "maxLength": 100},
        "color": {"type": ["string", "null"], "maxLength": 100},
        "machine_code": {"type": ["string", "null"], "maxLength": 50},
        "shift": {"type": ["string", "null"], "maxLength": 20},
        "bags": {"type": "integer", "minimum": 1},
        "weight_kg": {"type": "string", "pattern": "^[0-9]+\\.[0-9]{3}$"},
        "first_capture_at_utc": {"type": "string", "format": "date-time"},
        "last_capture_at_utc": {"type": "string", "format": "date-time"}
      }
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_version",
        "report_id",
        "generated_at_utc",
        "timezone",
        "window_start_date",
        "window_end_date",
        "source",
        "rows"
      ],
      "properties": {
        "contract_version": {"const": "station-production-progress-v1"},
        "report_id": {"type": "string", "format": "uuid"},
        "generated_at_utc": {"type": "string", "format": "date-time"},
        "timezone": {"const": "America/Lima"},
        "window_start_date": {"type": "string", "format": "date"},
        "window_end_date": {"type": "string", "format": "date"},
        "source": {"const": "LOCAL_REPORTED_LEGACY"},
        "rows": {
          "type": "array",
          "maxItems": 5000,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "operational_date",
              "op",
              "ot",
              "mold",
              "color",
              "machine_code",
              "shift",
              "bags",
              "weight_kg",
              "first_capture_at_utc",
              "last_capture_at_utc"
            ],
            "properties": {
              "operational_date": {"type": "string", "format": "date"},
              "op": {"type": ["string", "null"], "maxLength": 20},
              "ot": {"type": ["string", "null"], "maxLength": 20},
              "mold": {"type": ["string", "null"], "maxLength": 100},
              "color": {"type": ["string", "null"], "maxLength": 100},
              "machine_code": {"type": ["string", "null"], "maxLength": 50},
              "shift": {"type": ["string", "null"], "maxLength": 20},
              "bags": {"type": "integer", "minimum": 1},
              "weight_kg": {"type": "string", "pattern": "^[0-9]+\\.[0-9]{3}$"},
              "first_capture_at_utc": {"type": "string", "format": "date-time"},
              "last_capture_at_utc": {"type": "string", "format": "date-time"}
            }
          }
        }
      }
    },
    "response": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "accepted",
        "station_id",
        "report_id",
        "received_at_utc",
        "rows_applied",
        "window_start_date",
        "window_end_date"
      ],
      "properties": {
        "accepted": {"const": true},
        "station_id": {"type": "string", "format": "uuid"},
        "report_id": {"type": "string", "format": "uuid"},
        "received_at_utc": {"type": "string", "format": "date-time"},
        "rows_applied": {"type": "integer", "minimum": 0},
        "window_start_date": {"type": "string", "format": "date"},
        "window_end_date": {"type": "string", "format": "date"}
      }
    }
  }
}
